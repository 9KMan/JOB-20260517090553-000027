{
  "dashboard": {
    "title": "MLOps Platform Overview",
    "tags": ["mlops", "platform"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Model Deployment Status",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "count(sagemaker_model_total)",
            "legendFormat": "Models in Registry"
          },
          {
            "expr": "count(sagemaker_endpoint_status{status='InService'})",
            "legendFormat": "Endpoints Healthy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 1, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Prediction Latency p99 (ms)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "aws_sagemaker_model_latency_p99{service=\"fraud-detection\"}",
            "legendFormat": "{{ endpoint }} - p99"
          },
          {
            "expr": "aws_sagemaker_model_latency_p50{service=\"fraud-detection\"}",
            "legendFormat": "{{ endpoint }} - p50"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {"lineWidth": 2, "fillOpacity": 20}
          }
        }
      },
      {
        "id": 3,
        "title": "Drift Scores by Feature",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 10, "x": 14, "y": 0},
        "targets": [
          {
            "expr": "drift_score{feature=~\".*\"}",
            "legendFormat": "{{ feature }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.15, "color": "yellow"},
                {"value": 0.25, "color": "red"}
              ]
            },
            "min": 0,
            "max": 0.5
          }
        }
      },
      {
        "id": 4,
        "title": "Pipeline Success Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "sum(rate(airflow_dag_run_success[5m])) / sum(rate(airflow_dag_run_total[5m])) * 100",
            "legendFormat": "Success Rate %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 95, "color": "yellow"},
                {"value": 99, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Training Jobs",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "targets": [
          {
            "expr": "sagemaker_training_job_status",
            "legendFormat": "{{ job_name }} - {{ status }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"lineWidth": 1}
          }
        }
      },
      {
        "id": 6,
        "title": "Feature Store Coverage",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "targets": [
          {
            "expr": "feature_store_coverage_percentage",
            "legendFormat": "{{ feature_name }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Data Quality Score",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "data_quality_score",
            "legendFormat": "{{ table }} - {{ check_type }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.9, "color": "yellow"},
                {"value": 0.99, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "SLO Summary",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "transformations": [
          {
            "type": "seriesToRows",
            "options": {}
          }
        ],
        "targets": [
          {
            "expr": " slo_status",
            "format": "table",
            "instant": true
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Status"},
              "properties": [
                {"id": "mappings", "type": "value"},
                {"id": "thresholds", "type": "thresholds", "value": {
                  "mode": "absolute",
                  "steps": [
                    {"value": 0, "color": "green"},
                    {"value": 1, "color": "yellow"},
                    {"value": 2, "color": "red"}
                  ]
                }}
              ]}
          ]
        }
      }
    ]
  }
}